{
  "name": "storybook",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "storybook dev -p 6006",
    "build": "storybook build",
    "preview-storybook": "serve storybook-static",
    "clean": "rm -rf .turbo && rm -rf node_modules",
    "test": "vitest",
    "test-storybook": "vitest --project=storybook",
    "chromatic": "chromatic --exit-zero-on-changes --auto-accept-changes=main",
    "deploy:cf": "wrangler pages deploy storybook-static --project-name=keystoneui-storybook"
  },
  "dependencies": {
    "@keystoneui/react": "workspace:*",
    "@remixicon/react": "^4.9.0",
    "chrono-node": "^2.9.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "country-data-list": "^1.6.2",
    "date-fns": "^4.1.0",
    "embla-carousel-autoplay": "^8.6.0",
    "embla-carousel-wheel-gestures": "^8.1.0",
    "libphonenumber-js": "^1.12.42",
    "lucide-react": "^1.11.0",
    "react": "^19.2.5",
    "react-circle-flags": "^0.0.29",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.2.5",
    "react-icons": "^5.6.0",
    "react-resizable-panels": "^4.10.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.4"
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "@storybook/addon-docs": "^10.3.5",
    "@storybook/addon-links": "^10.3.5",
    "@storybook/addon-onboarding": "^10.3.5",
    "@storybook/addon-themes": "^10.3.5",
    "@storybook/addon-vitest": "^10.3.5",
    "@storybook/react": "^10.3.5",
    "@storybook/react-vite": "^10.3.5",
    "@tailwindcss/vite": "4.2.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/browser-playwright": "^4.1.5",
    "@vitest/coverage-v8": "^4.1.5",
    "chromatic": "^16.6.0",
    "playwright": "^1.59.1",
    "serve": "^14.2.6",
    "storybook": "^10.3.5",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "vitest": "^4.1.5",
    "wrangler": "^4.85.0"
